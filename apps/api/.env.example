NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# development: allows a fixed local test identity; required: verifies Supabase JWTs
# Production MUST use AUTH_MODE=required.
AUTH_MODE=development
SUPABASE_URL=
SUPABASE_JWT_AUDIENCE=authenticated
# Server-only secret. Required for in-app account deletion (removes the
# Supabase auth user). NEVER expose this to the mobile app or commit it.
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated user IDs allowed to use the community moderation endpoints.
ADMIN_USER_IDS=

# Optional in the first local run. Persistence is enabled when both values exist.
DATABASE_URL=
# Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=

AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional. WeatherAPI.com key — enables weather-aware chat suggestions when the
# mobile app sends the user's location. Leave blank to disable weather context.
WEATHER_API_KEY=

REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
