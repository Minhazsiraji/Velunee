{
  "expo": {
    "name": "Velunee",
    "slug": "velunee",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "velunee",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.velunee.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0B1F"
      },
      "package": "com.velunee.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
